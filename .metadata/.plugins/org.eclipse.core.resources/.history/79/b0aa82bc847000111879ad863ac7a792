package report;

import model.Student;
import java.util.List;
import java.util.OptionalDouble;
import java.util.Comparator;
import java.util.stream.Collectors;

public class ReportGenerator {
    public static int getTotalStudents(List<Student> students) {
        return students.size();
    }
    public static double getAverageMarks(List<Student> students) {
        OptionalDouble average = students.stream()
                .mapToDouble(Student::getMarks)
                .average();
        return average.orElse(0.0);
    }
    public static Student getTopper(List<Student> students) {
        return students.stream()
                .max(Comparator.comparingDouble(Student::getMarks))
                .orElse(null);
    }
    public static List<Student> getStudentsAbove80(List<Student> students) {
        return students.stream()
                .filter(s -> s.getMarks() > 80)
                .collect(Collectors.toList());
    }

    public static void summaryReport(List<Student> students) {
    	System.out.println("----------Student REPORT------------");
        if (students.isEmpty()) {
            System.out.println("No student records available to generate a report");
            return;
        }
        System.out.println("Total Students:"+getTotalStudents(students));
        System.out.printf("Average Marks: %.2f%n", getAverageMarks(students));
        Student topper = getTopper(students);
        System.out.println("Topper:");
        if (topper != null) {
            topper.displayDetails();
        }
        System.out.println("\nStudents Scoring Above 80%:");
        List<Student> topStudents = getStudentsAbove80(students);

        if (topStudents.isEmpty()) {
            System.out.println("None");
        } else {
            topStudents.forEach(Student::displayDetails);
        }
        System.out.println("----------------------");
    }
}